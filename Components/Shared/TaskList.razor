@* Components\Shared\TaskList.razor *@
@namespace Urchin.Components.Shared

<div class="tasklist">
    <div class="task-inner">
        @* List rendered twice — seamless loop: animate translateY(0) → translateY(-50%) *@
        @foreach (var pass in Enumerable.Range(0, 2))
        {
            @foreach (var task in _tasks)
            {
                <div class="task-row">
                    <span class="task-badge task-@task.Status">@task.StatusLabel</span>
                    <span class="task-text">@task.Text</span>
                </div>
            }
        }
    </div>
</div>

